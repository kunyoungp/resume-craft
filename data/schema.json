{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/jsonresume/resume-schema/master/schema.json",
  "title": "JSON Resume",
  "description": "A JSON-based standard for resumes. Reference schema for resume-craft profile.json files.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "basics": {
      "type": "object",
      "description": "Basic personal information",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name"
        },
        "label": {
          "type": "string",
          "description": "Job title or role (e.g. 'Senior Software Engineer')"
        },
        "image": {
          "type": "string",
          "description": "URL to a profile image",
          "format": "uri"
        },
        "email": {
          "type": "string",
          "description": "Contact email address",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number (free-form string)"
        },
        "url": {
          "type": "string",
          "description": "Personal website URL",
          "format": "uri"
        },
        "summary": {
          "type": "string",
          "description": "A short professional summary or objective"
        },
        "location": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "address": {
              "type": "string",
              "description": "Street address"
            },
            "postalCode": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "countryCode": {
              "type": "string",
              "description": "ISO 3166-1 alpha-2 country code (e.g. 'US', 'KR')"
            },
            "region": {
              "type": "string",
              "description": "State, province, or region"
            }
          }
        },
        "profiles": {
          "type": "array",
          "description": "Social media and professional network profiles",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "network": {
                "type": "string",
                "description": "Network name (e.g. 'LinkedIn', 'GitHub')"
              },
              "username": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "description": "Profile URL",
                "format": "uri"
              }
            }
          }
        }
      }
    },
    "work": {
      "type": "array",
      "description": "Work experience entries",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Company or organization name"
          },
          "position": {
            "type": "string",
            "description": "Job title"
          },
          "url": {
            "type": "string",
            "description": "Company website",
            "format": "uri"
          },
          "startDate": {
            "type": "string",
            "description": "Start date in YYYY-MM-DD or YYYY-MM format",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "endDate": {
            "type": "string",
            "description": "End date in YYYY-MM-DD or YYYY-MM format (omit if current)",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "summary": {
            "type": "string",
            "description": "Brief description of the role"
          },
          "highlights": {
            "type": "array",
            "description": "Key accomplishments or responsibilities",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "volunteer": {
      "type": "array",
      "description": "Volunteer experience entries",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "organization": {
            "type": "string",
            "description": "Organization name"
          },
          "position": {
            "type": "string",
            "description": "Volunteer role"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "startDate": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "endDate": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "summary": {
            "type": "string"
          },
          "highlights": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "education": {
      "type": "array",
      "description": "Education history",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "institution": {
            "type": "string",
            "description": "School or university name"
          },
          "url": {
            "type": "string",
            "description": "Institution website",
            "format": "uri"
          },
          "area": {
            "type": "string",
            "description": "Field of study (e.g. 'Computer Science')"
          },
          "studyType": {
            "type": "string",
            "description": "Degree type (e.g. 'Bachelor', 'Master', 'PhD')"
          },
          "startDate": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "endDate": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "score": {
            "type": "string",
            "description": "GPA or grade"
          },
          "courses": {
            "type": "array",
            "description": "Notable courses taken",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "awards": {
      "type": "array",
      "description": "Awards and recognitions",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "title": {
            "type": "string",
            "description": "Award name"
          },
          "date": {
            "type": "string",
            "description": "Date awarded",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "awarder": {
            "type": "string",
            "description": "Awarding body"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "certificates": {
      "type": "array",
      "description": "Professional certifications",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Certificate name"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "issuer": {
            "type": "string",
            "description": "Issuing organization"
          },
          "url": {
            "type": "string",
            "description": "Verification URL",
            "format": "uri"
          }
        }
      }
    },
    "publications": {
      "type": "array",
      "description": "Published works",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Publication title"
          },
          "publisher": {
            "type": "string"
          },
          "releaseDate": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "description": "Professional skills grouped by category",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Skill category (e.g. 'Frontend Development')"
          },
          "level": {
            "type": "string",
            "description": "Proficiency level (e.g. 'Beginner', 'Intermediate', 'Advanced', 'Master')"
          },
          "keywords": {
            "type": "array",
            "description": "Specific technologies or abilities in this category",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "languages": {
      "type": "array",
      "description": "Language proficiencies",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "language": {
            "type": "string",
            "description": "Language name (e.g. 'English', 'Korean')"
          },
          "fluency": {
            "type": "string",
            "description": "Fluency level (e.g. 'Native speaker', 'Professional working proficiency')"
          }
        }
      }
    },
    "interests": {
      "type": "array",
      "description": "Personal interests",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Interest category"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "references": {
      "type": "array",
      "description": "Professional references",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Reference person's name"
          },
          "reference": {
            "type": "string",
            "description": "Reference text or testimonial"
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "description": "Personal or professional projects",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Project name"
          },
          "description": {
            "type": "string",
            "description": "Short project description"
          },
          "highlights": {
            "type": "array",
            "description": "Key achievements or features",
            "items": {
              "type": "string"
            }
          },
          "keywords": {
            "type": "array",
            "description": "Technologies or tags",
            "items": {
              "type": "string"
            }
          },
          "startDate": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "endDate": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
          },
          "url": {
            "type": "string",
            "description": "Project URL",
            "format": "uri"
          },
          "roles": {
            "type": "array",
            "description": "Roles held in the project",
            "items": {
              "type": "string"
            }
          },
          "entity": {
            "type": "string",
            "description": "Organization or entity the project was for"
          },
          "type": {
            "type": "string",
            "description": "Project type (e.g. 'application', 'library', 'research')"
          }
        }
      }
    }
  }
}
